    private async Task<bool> ConfirmVariantBeforeExportAsync()
    {
        var speichern = await Js.InvokeAsync<bool>("confirm", "Moechtest du den aktuellen Stand vor dem Export als gespeicherte Variante sichern?");
        if (!speichern)
        {
            return true;
        }

        var vorgeschlagen = $"Variante {DateTime.Now:yyyy-MM-dd HH:mm}";
        var name = await Js.InvokeAsync<string?>("prompt", "Name fuer gespeicherte Variante:", vorgeschlagen);
        if (name is null)
        {
            return false;
        }

        await Vm.VarianteSpeichernAsync(name);
        return string.IsNullOrWhiteSpace(Vm.ErrorMessage);
    }

    private async Task FreshStartAsync()
    {
        var confirmed = await Js.InvokeAsync<bool>("confirm", "Alle Arbeitsversionen und gespeicherten Varianten loeschen?");
        if (!confirmed)
        {
            return;
        }

        await Vm.ResetAllDataAsync();
        Navigation.NavigateTo("/", replace: true);
    }

    private void UpdateBullets(CvStudio.Application.Contracts.WorkItemData item, string? input)
    {
        item.Bullets = SplitLines(input);
        Vm.OnEditorChanged();
    }

    private void UpdateSkillItems(CvStudio.Application.Contracts.SkillGroupData group, string? input)
    {
        group.Items = SplitComma(input);
        Vm.OnEditorChanged();
    }

    private void UpdateHobbies(string? input)
    {
        if (Vm.CurrentResume is null)
        {
            return;
        }

        Vm.CurrentResume.ResumeData.Hobbies = SplitLines(input);
        Vm.OnEditorChanged();
    }

    private static List<string> SplitLines(string? input)
    {
        return (input ?? string.Empty)
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
    }

    private static List<string> SplitComma(string? input)
    {
        return (input ?? string.Empty)
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();
    }

    private void AddWork()
    {
        Vm.CurrentResume?.ResumeData.WorkItems.Add(new CvStudio.Application.Contracts.WorkItemData());
        Vm.OnEditorChanged();
    }

    private void RemoveWork(int index)
    {
        if (Vm.CurrentResume is null || index < 0 || index >= Vm.CurrentResume.ResumeData.WorkItems.Count)
        {
            return;
        }

        Vm.CurrentResume.ResumeData.WorkItems.RemoveAt(index);
        Vm.OnEditorChanged();
    }


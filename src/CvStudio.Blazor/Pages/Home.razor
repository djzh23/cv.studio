@page "/"
@page "/arbeitsversion/{Id:guid}"
@page "/resume/{Id:guid}"
@implements IDisposable
@rendermode InteractiveServer
@inject ResumeEditorViewModel Vm
@inject NavigationManager Navigation
@inject IJSRuntime Js
@inject CvStudio.Blazor.Services.PasscodeGateService Gate
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using CvStudio.Application.Services
@using CvStudio.Application.Contracts

<PageTitle>CvStudio</PageTitle>

@if (!_accessChecked)
{
    <section class="empty-state">
        <h1>CvStudio</h1>
        <p>Session wird geprueft...</p>
    </section>
}
else if (!Gate.HasAccess)
{
    <section class="empty-state">
        <h1>CvStudio</h1>
        <p>Weiterleitung zur Code-Eingabe...</p>
    </section>
}
else if (Vm.CurrentResume is null)
{
    <section class="empty-state">
        <h1>CvStudio</h1>
        <p>1) Vorlage waehlen. 2) Arbeitsversion erstellen. 3) Varianten speichern und exportieren.</p>

        @if (Vm.Vorlagen.Count == 0)
        {
            <div class="alert alert-warning" role="alert">
                Vorlagen konnten aktuell nicht geladen werden. Bitte erneut versuchen.
            </div>
        }
        else
        {
            <div class="template-grid">
                @foreach (var vorlage in Vm.Vorlagen)
                {
                    <button type="button"
                            class='template-card @(Vm.GewaehlteVorlage == vorlage.Key ? "active" : string.Empty)'
                            @onclick='() => Vm.GewaehlteVorlage = vorlage.Key'
                            disabled="@Vm.IsBusy">
                        <i class="@TemplateIconClass(vorlage.Key) template-icon"></i>
                        <strong>@vorlage.DisplayName</strong>
                        <span>@vorlage.Description</span>
                    </button>
                }
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Vm.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Vm.ErrorMessage</div>
        }

        <div class="toolbar-actions">
            <button class="btn btn-secondary" @onclick="ReloadTemplatesAsync" disabled="@Vm.IsBusy"><i class="bi bi-arrow-repeat"></i> Vorlagen neu laden</button>
            <button class="btn btn-primary" @onclick="NeueArbeitsversionAsync" disabled="@Vm.IsBusy"><i class="bi bi-plus-circle"></i> Arbeitsversion erstellen</button>
            <button class="btn btn-danger" @onclick="FreshStartAsync" disabled="@Vm.IsBusy"><i class="bi bi-trash3"></i> Fresh Start</button>
        </div>

        @if (Vm.Arbeitsversionen.Count > 0)
        {
            <section class="versions-panel" style="margin-top: 1rem; text-align: left;">
                <h2>Bestehende Arbeitsversionen</h2>
                <div class="versions-list">
                    @foreach (var arbeitsversion in Vm.Arbeitsversionen.Take(12))
                    {
                        <button class="version-item" @onclick="() => OeffneArbeitsversion(arbeitsversion.Id)">
                            <strong>@arbeitsversion.Title</strong>
                            <span>ID: @arbeitsversion.Id</span>
                            <small>Zuletzt geaendert: @arbeitsversion.UpdatedAtUtc.ToLocalTime().ToString("g")</small>
                        </button>
                    }
                </div>
            </section>
        }
    </section>
}
else
{
    <section class="resume-shell">
        <header class="toolbar">
            <div class="toolbar-left">
                <h1>@Vm.CurrentResume.Title</h1>
                <small class="header-meta-row">
                    <span><i class="bi bi-pencil-square"></i> Du bearbeitest: @Vm.AktivKontextText</span>
                    <span class="meta-dot">&bull;</span>
                    <span class="autosave-state"><span class="autosave-dot"></span>@Vm.AutoSaveText</span>
                </small>
                <small class="mono-meta">Arbeitsversion-ID: @Vm.CurrentResume.Id</small>
            </div>
            <div class="toolbar-actions">
                <button class="btn btn-primary" @onclick="NeueArbeitsversionAsync" disabled="@Vm.IsBusy"><i class="bi bi-plus-circle"></i> Neue Arbeitsversion</button>
                <button class="btn btn-secondary" @onclick='() => Navigation.NavigateTo($"/varianten/{Vm.CurrentResume.Id}")'><i class="bi bi-git"></i> Varianten verwalten</button>
            </div>
        </header>

        <section class="versions-panel">
            <h2 class="section-label"><i class="bi bi-grid-3x3-gap"></i> Neue Arbeitsversion aus Vorlage</h2>
            <div class="template-grid">
                @foreach (var vorlage in Vm.Vorlagen)
                {
                    <button type="button"
                            class='template-card @(Vm.GewaehlteVorlage == vorlage.Key ? "active" : string.Empty)'
                            @onclick='() => Vm.GewaehlteVorlage = vorlage.Key'
                            disabled="@Vm.IsBusy">
                        <i class="@TemplateIconClass(vorlage.Key) template-icon"></i>
                        <strong>@vorlage.DisplayName</strong>
                        <span>@vorlage.Description</span>
                    </button>
                }
            </div>
            <div class="toolbar-actions">
                <button class="btn btn-primary" @onclick="NeueArbeitsversionAsync" disabled="@Vm.IsBusy"><i class="bi bi-plus-circle"></i> Arbeitsversion mit gewaehlter Vorlage erstellen</button>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Vm.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Vm.ErrorMessage</div>
        }

        <div class="context-banner" role="status">
            <i class="bi bi-pencil-square"></i>
            <strong>Du bearbeitest: @Vm.AktivKontextText</strong>
        </div>

        <main class="grid-area">
            <section class="editor-panel">
                <div class="editor-scroll">
                    @if (_editContext is not null)
                    {
                        <EditForm EditContext="_editContext">
                            <DataAnnotationsValidator />
                            <ValidationSummary />

                            <div class="editor-toolbar">
                                <div class="toolbar-actions-row">
                                    <div class="toolbar-left">
                                        <span class="editing-label"><i class="bi bi-pencil-square"></i> Du bearbeitest: @Vm.AktivKontextText</span>
                                    </div>
                                    <div class="toolbar-right">
                                        <div class="export-group">
                                            <InputSelect class="design-select" @bind-Value="Vm.AusgewaehltesPdfDesign">
                                                <option value="@PdfDesign.DesignA">Design A — Klassisch (ATS)</option>
                                                <option value="@PdfDesign.DesignB">Design B — Modern</option>
                                                <option value="@PdfDesign.DesignC">Design C — Professional</option>
                                            </InputSelect>
                                            <button class="btn btn-export-pdf btn-md" @onclick="ExportArbeitsversionPdfAsync" disabled="@Vm.IsBusy"><i class="bi bi-download"></i> PDF</button>
                                        </div>
                                        <button class="btn btn-export-docx btn-md" @onclick="ExportArbeitsversionDocxAsync" disabled="@Vm.IsBusy"><i class="bi bi-download"></i> DOCX</button>
                                        <button class="btn btn-secondary btn-md" @onclick="OpenAtsModal" disabled="@Vm.IsBusy"><i class="bi bi-bullseye"></i> ATS prüfen</button>
                                        <div class="save-dropdown-container">
                                            <button class="btn btn-primary btn-md" @onclick="ToggleSaveDropdown" disabled="@Vm.IsBusy"><i class="bi bi-floppy"></i> Variante speichern</button>
                                            @if (_showSaveDropdown)
                                            {
                                                <div class="save-dropdown">
                                                    <div class="save-dropdown-title">Variante speichern</div>
                                                    <input class="form-control" placeholder="z.B. SAP Bewerbung" @bind="Vm.VariantenNameEntwurf" />
                                                    <div class="save-dropdown-actions">
                                                        <button class="btn btn-secondary" @onclick="SaveWithoutExportAsync" disabled="@Vm.IsBusy">Speichern ohne Export</button>
                                                        <button class="btn btn-primary" @onclick="SaveAndExportPdfAsync" disabled="@Vm.IsBusy">Speichern + PDF exportieren</button>
                                                        <button class="btn btn-primary" @onclick="SaveAndExportDocxAsync" disabled="@Vm.IsBusy">Speichern + DOCX exportieren</button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="toolbar-tabs-row">
                                    <button type="button" class='tab-btn @TabClass("profil")' @onclick='() => ActiveTab = "profil"'><i class="bi bi-person"></i> Profil</button>
                                    <button type="button" class='tab-btn @TabClass("beruf")' @onclick='() => ActiveTab = "beruf"'><i class="bi bi-building"></i> Beruf</button>
                                    <button type="button" class='tab-btn @TabClass("ausbildung")' @onclick='() => ActiveTab = "ausbildung"'><i class="bi bi-mortarboard"></i> Ausbildung</button>
                                    <button type="button" class='tab-btn @TabClass("kenntnisse")' @onclick='() => ActiveTab = "kenntnisse"'><i class="bi bi-tools"></i> Kenntnisse</button>
                                    <button type="button" class='tab-btn @TabClass("hobby")' @onclick='() => ActiveTab = "hobby"'><i class="bi bi-heart"></i> Hobbys</button>
                                </div>
                            </div>

                            @if (ActiveTab == "profil")
                            {
                                <div class="tab-content">
                                <h2>Profil</h2>
                                <div class="field-grid">
                                    <label>Titel <InputText class="form-control" @bind-Value="Vm.CurrentResume.Title" /></label>
                                    <label>Vorname <InputText class="form-control" @bind-Value="Vm.CurrentResume.ResumeData.Profile.FirstName" /></label>
                                    <label>Nachname <InputText class="form-control" @bind-Value="Vm.CurrentResume.ResumeData.Profile.LastName" /></label>
                                    <label>Headline <InputText class="form-control" @bind-Value="Vm.CurrentResume.ResumeData.Profile.Headline" /></label>
                                    <label>E-Mail <InputText class="form-control" @bind-Value="Vm.CurrentResume.ResumeData.Profile.Email" /></label>
                                    <label>Telefon <InputText class="form-control" @bind-Value="Vm.CurrentResume.ResumeData.Profile.Phone" /></label>
                                    <label>Ort <InputText class="form-control" @bind-Value="Vm.CurrentResume.ResumeData.Profile.Location" /></label>
                                    <label>Profilbild URL <InputText class="form-control" @bind-Value="Vm.CurrentResume.ResumeData.Profile.ProfileImageUrl" /></label>
                                </div>

                                <div class="form-section-divider">
                                    <span>Online-Profile <small>(optional)</small></span>
                                </div>
                                <div class="field-grid">
                                    <label>LinkedIn-URL
                                        <InputText class="form-control" @bind-Value="Vm.CurrentResume.ResumeData.Profile.LinkedInUrl" />
                                        <small class="form-hint">Wird im PDF nur angezeigt wenn ausgefuellt.</small>
                                    </label>
                                    <label>GitHub-URL
                                        <InputText class="form-control" @bind-Value="Vm.CurrentResume.ResumeData.Profile.GitHubUrl" />
                                    </label>
                                    <label>Portfolio / Website
                                        <InputText class="form-control" @bind-Value="Vm.CurrentResume.ResumeData.Profile.PortfolioUrl" />
                                    </label>
                                    <label>Arbeitsgenehmigung
                                        <input class="form-control"
                                               type="text"
                                               list="work-permit-options"
                                               placeholder="Arbeitsgenehmigung eingeben oder auswaehlen..."
                                               @bind="Vm.CurrentResume.ResumeData.Profile.WorkPermit"
                                               @bind:event="oninput" />
                                        <small class="form-hint">Erscheint als diskreter Hinweis im PDF-Header.</small>
                                    </label>
                                </div>
                                <datalist id="work-permit-options">
                                    <option value="EU-Staatsbuerger · Unbeschraenkte Arbeitserlaubnis Deutschland" />
                                    <option value="Aufenthaltstitel § 18b AufenthG · Unbeschraenkte Arbeitserlaubnis" />
                                    <option value="Niederlassungserlaubnis · Dauerhaft arbeitsberechtigt in Deutschland" />
                                    <option value="EU Blue Card · Hochqualifiziert arbeitsberechtigt in Deutschland" />
                                </datalist>
                                <label>Qualifikationsprofil
                                    <InputTextArea class="form-control" @bind-Value="Vm.CurrentResume.ResumeData.Profile.Summary" rows="6" />
                                </label>
                                </div>
                            }

                            @if (ActiveTab == "beruf")
                            {
                                <div class="tab-content">
                                <h2>Berufserfahrung</h2>
                                @for (var i = 0; i < Vm.CurrentResume.ResumeData.WorkItems.Count; i++)
                                {
                                    var index = i;
                                    var item = Vm.CurrentResume.ResumeData.WorkItems[i];
                                    <div class="list-card">
                                        <div class="field-grid">
                                            <label>Unternehmen <InputText class="form-control" @bind-Value="item.Company" /></label>
                                            <label>Rolle <InputText class="form-control" @bind-Value="item.Role" /></label>
                                            <label>Start <InputText class="form-control" @bind-Value="item.StartDate" /></label>
                                            <label>Ende <InputText class="form-control" @bind-Value="item.EndDate" /></label>
                                        </div>
                                        <label>Kurzbeschreibung
                                            <InputTextArea class="form-control" @bind-Value="item.Description" rows="3" />
                                        </label>
                                        <label>Stichpunkte (eine Zeile = ein Punkt)
                                            <textarea class="form-control" rows="4" value="@string.Join('\n', item.Bullets)" @onchange="e => UpdateBullets(item, e.Value?.ToString())"></textarea>
                                        </label>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveWork(index)"><i class="bi bi-trash3"></i> Entfernen</button>
                                    </div>
                                }
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="AddWork"><i class="bi bi-plus-circle"></i> Eintrag hinzufuegen</button>
                                </div>
                            }

                            @if (ActiveTab == "ausbildung")
                            {
                                <div class="tab-content">
                                <h2>Ausbildung</h2>
                                @for (var i = 0; i < Vm.CurrentResume.ResumeData.EducationItems.Count; i++)
                                {
                                    var index = i;
                                    var item = Vm.CurrentResume.ResumeData.EducationItems[i];
                                    <div class="list-card">
                                        <div class="field-grid">
                                            <label>Schule <InputText class="form-control" @bind-Value="item.School" /></label>
                                            <label>Abschluss <InputText class="form-control" @bind-Value="item.Degree" /></label>
                                            <label>Start <InputText class="form-control" @bind-Value="item.StartDate" /></label>
                                            <label>Ende <InputText class="form-control" @bind-Value="item.EndDate" /></label>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveEducation(index)"><i class="bi bi-trash3"></i> Entfernen</button>
                                    </div>
                                }
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="AddEducation"><i class="bi bi-plus-circle"></i> Eintrag hinzufuegen</button>
                                </div>
                            }

                            @if (ActiveTab == "kenntnisse")
                            {
                                <div class="tab-content">
                                <h2>Kenntnisse</h2>
                                @for (var i = 0; i < Vm.CurrentResume.ResumeData.Skills.Count; i++)
                                {
                                    var index = i;
                                    var group = Vm.CurrentResume.ResumeData.Skills[i];
                                    <div class="list-card">
                                        <div class="field-grid">
                                            <label>Kategorie <InputText class="form-control" @bind-Value="group.CategoryName" /></label>
                                            <label>Eintraege (kommagetrennt)
                                                <input class="form-control" value="@string.Join(", ", group.Items)" @onchange="e => UpdateSkillItems(group, e.Value?.ToString())" />
                                            </label>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveSkill(index)"><i class="bi bi-trash3"></i> Entfernen</button>
                                    </div>
                                }
                                <button type="button" class="btn btn-sm btn-secondary" @onclick="AddSkill"><i class="bi bi-plus-circle"></i> Kategorie hinzufuegen</button>
                                </div>
                            }

                            @if (ActiveTab == "hobby")
                            {
                                <div class="tab-content">
                                <h2>Hobbys</h2>
                                <label>Hobbys (eine Zeile = ein Hobby)
                                    <textarea class="form-control" rows="8" value="@string.Join('\n', Vm.CurrentResume.ResumeData.Hobbies)" @onchange="e => UpdateHobbies(e.Value?.ToString())"></textarea>
                                </label>
                                </div>
                            }
                        </EditForm>
                    }
                </div>
            </section>

            <section class="preview-panel">
                <h2 class="preview-label"><i class="bi bi-eye"></i> Live-Vorschau</h2>
                <div class="preview-scroll">
                    <div class="preview-card @(Vm.AusgewaehltesPdfDesign == PdfDesign.DesignB ? "preview-design-b" : "")">
                        <div class="preview-header">
                            @if (!string.IsNullOrWhiteSpace(Vm.CurrentResume.ResumeData.Profile.ProfileImageUrl))
                            {
                                <img class="profile-image" src="@Vm.CurrentResume.ResumeData.Profile.ProfileImageUrl" alt="Profile image" />
                            }
                            <div>
                                <h3>@Vm.CurrentResume.ResumeData.Profile.FirstName @Vm.CurrentResume.ResumeData.Profile.LastName</h3>
                                <p class="muted">@Vm.CurrentResume.ResumeData.Profile.Headline</p>
                            </div>
                        </div>
                        <p class="muted">@Vm.CurrentResume.ResumeData.Profile.Email | @Vm.CurrentResume.ResumeData.Profile.Phone | @Vm.CurrentResume.ResumeData.Profile.Location</p>
                        @if (HasSocialLinks(Vm.CurrentResume.ResumeData.Profile))
                        {
                            <div class="cv-social-links">
                                @if (!string.IsNullOrWhiteSpace(Vm.CurrentResume.ResumeData.Profile.LinkedInUrl))
                                {
                                    <span class="cv-social-link cv-social-li">in @FormatUrl(Vm.CurrentResume.ResumeData.Profile.LinkedInUrl)</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(Vm.CurrentResume.ResumeData.Profile.GitHubUrl))
                                {
                                    <span class="cv-social-link cv-social-gh">gh @FormatUrl(Vm.CurrentResume.ResumeData.Profile.GitHubUrl)</span>
                                }
                                @if (!string.IsNullOrWhiteSpace(Vm.CurrentResume.ResumeData.Profile.PortfolioUrl))
                                {
                                    <span class="cv-social-link cv-social-web">web @FormatUrl(Vm.CurrentResume.ResumeData.Profile.PortfolioUrl)</span>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Vm.CurrentResume.ResumeData.Profile.WorkPermit))
                        {
                            <div class="cv-work-permit">✓ @Vm.CurrentResume.ResumeData.Profile.WorkPermit</div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Vm.CurrentResume.ResumeData.Profile.Summary))
                        {
                            <h4>Qualifikationsprofil</h4>
                            <p>@Vm.CurrentResume.ResumeData.Profile.Summary</p>
                        }

                        <h4>Berufserfahrung</h4>
                        @if (Vm.CurrentResume.ResumeData.WorkItems.Count == 0)
                        {
                            <p class="muted">Keine Eintraege</p>
                        }
                        else
                        {
                            @foreach (var work in Vm.CurrentResume.ResumeData.WorkItems)
                            {
                                <article>
                                    <strong>@work.Role - @work.Company</strong>
                                    <div class="muted">@work.StartDate - @work.EndDate</div>
                                    @if (!string.IsNullOrWhiteSpace(work.Description))
                                    {
                                        <p>@work.Description</p>
                                    }
                                    @if (work.Bullets.Count > 0)
                                    {
                                        <ul>
                                            @foreach (var bullet in work.Bullets)
                                            {
                                                <li>@bullet</li>
                                            }
                                        </ul>
                                    }
                                </article>
                            }
                        }

                        <h4>Ausbildung</h4>
                        @if (Vm.CurrentResume.ResumeData.EducationItems.Count == 0)
                        {
                            <p class="muted">Keine Eintraege</p>
                        }
                        else
                        {
                            @foreach (var edu in Vm.CurrentResume.ResumeData.EducationItems)
                            {
                                <article>
                                    <strong>@edu.Degree</strong>
                                    <div>@edu.School</div>
                                    <div class="muted">@edu.StartDate - @edu.EndDate</div>
                                </article>
                            }
                        }

                        <h4>Kenntnisse</h4>
                        @if (Vm.CurrentResume.ResumeData.Skills.Count == 0)
                        {
                            <p class="muted">Keine Eintraege</p>
                        }
                        else
                        {
                            @foreach (var skill in Vm.CurrentResume.ResumeData.Skills)
                            {
                                <div><strong>@skill.CategoryName:</strong> @string.Join(", ", skill.Items)</div>
                            }
                        }

                        <h4>Hobbys</h4>
                        @if (Vm.CurrentResume.ResumeData.Hobbies.Count == 0)
                        {
                            <p class="muted">Keine Eintraege</p>
                        }
                        else
                        {
                            <p>@string.Join(" | ", Vm.CurrentResume.ResumeData.Hobbies)</p>
                        }
                    </div>
                </div>
            </section>
        </main>

        <section class="versions-panel">
            <h2><i class="bi bi-layers"></i> Gespeicherte Varianten</h2>
            <p class="muted">2. Schritt: Variante speichern. 3. Schritt: Direkt aus Variante exportieren.</p>

            @if (Vm.GespeicherteVarianten.Count == 0)
            {
                <p class="muted">Noch keine gespeicherte Variante vorhanden.</p>
            }
            else
            {
                <div class="versions-list">
                    @foreach (var variante in Vm.GespeicherteVarianten)
                    {
                        <div class="version-item">
                            <strong><span class='version-badge @VersionBadgeClass(variante.VersionNumber)'>v@(variante.VersionNumber)</span> @ResumeEditorViewModel.FormatVariantenName(variante)</strong>
                            <small>@variante.CreatedAtUtc.ToLocalTime().ToString("g")</small>
                            <div class="toolbar-actions">
                                <button class="btn btn-sm btn-ghost" @onclick="() => VarianteLadenAsync(variante.Id)"><i class="bi bi-pencil-square"></i> Als Arbeitsversion laden</button>
                                <button class="btn btn-sm btn-export-pdf" @onclick="() => ExportVariantePdfAsync(variante)"><i class="bi bi-download"></i> PDF</button>
                                <button class="btn btn-sm btn-export-docx" @onclick="() => ExportVarianteDocxAsync(variante)"><i class="bi bi-download"></i> DOCX</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </section>

    <AtsCheckerModal IsOpen="_atsModalOpen"
                     OnClose="CloseAtsModal"
                     OnExportAnyway="ExportFromAtsModalAsync"
                     CurrentResume="GetCurrentResumeForAts()"
                     LastSnapshotResume="GetLastSnapshotForAts()" />
}

@code {
    [Parameter]
    public Guid? Id { get; set; }

    [SupplyParameterFromQuery]
    public Guid? VersionId { get; set; }

    private string ActiveTab { get; set; } = "profil";
    private EditContext? _editContext;
    private ResumeDto? _editModel;
    private bool _accessChecked;
    private bool _bootstrapCompleted;
    private bool _showSaveDropdown;
    private bool _atsModalOpen;

    protected override async Task OnInitializedAsync()
    {
        Vm.StateChanged += OnVmStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_accessChecked)
        {
            await Gate.EnsureInitializedAsync();
            _accessChecked = true;
            if (!Gate.HasAccess)
            {
                RedirectToAccess();
                return;
            }
        }

        if (!Gate.HasAccess || _bootstrapCompleted)
        {
            return;
        }

        _bootstrapCompleted = true;
        await Vm.LoadTemplatesAsync();
        await TryLoadFromRouteOrLastAsync();
        EnsureEditContext();
        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_bootstrapCompleted || !Gate.HasAccess)
        {
            return;
        }

        if (Id.HasValue && Vm.CurrentResume?.Id != Id.Value)
        {
            await Vm.ArbeitsversionLadenAsync(Id.Value);
            if (VersionId.HasValue)
            {
                await Vm.VarianteInEditorLadenAsync(VersionId.Value);
            }
            EnsureEditContext();
        }
        else if (Id.HasValue && VersionId.HasValue)
        {
            await Vm.VarianteInEditorLadenAsync(VersionId.Value);
            EnsureEditContext();
        }
    }

    private void RedirectToAccess()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        var returnUrl = string.IsNullOrWhiteSpace(relative) ? "/" : $"/{relative}";
        Navigation.NavigateTo($"/access?returnUrl={Uri.EscapeDataString(returnUrl)}", replace: true);
    }

    private async Task TryLoadFromRouteOrLastAsync()
    {
        if (Id.HasValue)
        {
            await Vm.ArbeitsversionLadenAsync(Id.Value);
            return;
        }

        var lastResumeId = await Vm.TryGetLastResumeIdAsync();
        if (lastResumeId.HasValue)
        {
            await Vm.ArbeitsversionLadenAsync(lastResumeId.Value);
            if (Vm.CurrentResume is not null)
            {
                Navigation.NavigateTo($"/arbeitsversion/{Vm.CurrentResume.Id}", replace: true);
            }
        }
    }

    private void EnsureEditContext()
    {
        if (Vm.CurrentResume is null)
        {
            _editContext = null;
            _editModel = null;
            return;
        }

        if (ReferenceEquals(_editModel, Vm.CurrentResume) && _editContext is not null)
        {
            return;
        }

        if (_editContext is not null)
        {
            _editContext.OnFieldChanged -= EditContextOnFieldChanged;
        }

        _editModel = Vm.CurrentResume;
        _editContext = new EditContext(_editModel);
        _editContext.OnFieldChanged += EditContextOnFieldChanged;
    }

    private void EditContextOnFieldChanged(object? sender, FieldChangedEventArgs e)
    {
        Vm.OnEditorChanged();
    }

    private string TabClass(string tabName) => ActiveTab == tabName ? "active" : string.Empty;

    private static string TemplateIconClass(string templateKey) => templateKey switch
    {
        "softwareentwickler" => "bi bi-code-slash",
        "it-support" => "bi bi-headset",
        "service-gastro-zustellung" => "bi bi-briefcase",
        _ => "bi bi-file-earmark-text"
    };

    private static string VersionBadgeClass(int versionNumber)
    {
        var normalized = Math.Max(versionNumber, 1);
        var index = (normalized - 1) % 3;
        return index switch
        {
            0 => "badge-v1",
            1 => "badge-v2",
            _ => "badge-v3"
        };
    }

    private static bool HasSocialLinks(ProfileData profile)
    {
        return !string.IsNullOrWhiteSpace(profile.LinkedInUrl)
            || !string.IsNullOrWhiteSpace(profile.GitHubUrl)
            || !string.IsNullOrWhiteSpace(profile.PortfolioUrl);
    }

    private static string FormatUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return string.Empty;
        }

        return url
            .Replace("https://", string.Empty, StringComparison.OrdinalIgnoreCase)
            .Replace("http://", string.Empty, StringComparison.OrdinalIgnoreCase)
            .TrimEnd('/')
            .Trim();
    }


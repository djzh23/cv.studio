    private void OnVmStateChanged()
    {
        EnsureEditContext();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Vm.StateChanged -= OnVmStateChanged;
        if (_editContext is not null)
        {
            _editContext.OnFieldChanged -= EditContextOnFieldChanged;
        }
    }

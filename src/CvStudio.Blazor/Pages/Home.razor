    private async Task SaveAndExportPdfAsync()
    {
        var variante = await Vm.VarianteSpeichernAsync();
        if (variante is null)
        {
            return;
        }

        var bytes = await Vm.ExportVariantePdfAsync(variante.Id);
        if (bytes.Length == 0)
        {
            return;
        }

        var name = ResumeEditorViewModel.FormatVariantenName(variante).Replace(' ', '-');
        await Js.InvokeVoidAsync("CvStudio.downloadFile", $"variante-{name}.pdf", Convert.ToBase64String(bytes), "application/pdf");
        _showSaveDropdown = false;
    }


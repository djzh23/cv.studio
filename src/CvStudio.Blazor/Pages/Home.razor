    private async Task ExportArbeitsversionPdfAsync()
    {
        if (!await ConfirmVariantBeforeExportAsync())
        {
            return;
        }

        var bytes = await Vm.ExportArbeitsversionPdfAsync();
        if (Vm.CurrentResume is null || bytes.Length == 0)
        {
            return;
        }

        await Js.InvokeVoidAsync("CvStudio.downloadFile", $"arbeitsversion-{Vm.CurrentResume.Id}.pdf", Convert.ToBase64String(bytes), "application/pdf");
    }


@page "/varianten"
@page "/varianten/{ResumeId:guid}"
@page "/versions"
@page "/versions/{ResumeId:guid}"
@rendermode InteractiveServer
@inject CvStudio.Blazor.Services.ResumeApiClient Api
@inject NavigationManager Navigation
@inject IJSRuntime Js
@inject CvStudio.Blazor.Services.PasscodeGateService Gate
@using CvStudio.Application.Services

<PageTitle>Varianten verwalten</PageTitle>

@if (!_accessChecked)
{
    <section class="empty-state">
        <h1>Varianten</h1>
        <p>Session wird geprueft...</p>
    </section>
}
else if (!Gate.HasAccess)
{
    <section class="empty-state">
        <h1>Varianten</h1>
        <p>Weiterleitung zur Code-Eingabe...</p>
    </section>
}
else
{
<section class="resume-shell">
    <header class="toolbar">
        <div class="toolbar-left">
            <h1>Gespeicherte Varianten</h1>
            <small>@(CurrentArbeitsversionTitle ?? "Arbeitsversion waehlen")</small>
            @if (ActiveArbeitsversionId.HasValue)
            {
                <small>Arbeitsversion-ID: @ActiveArbeitsversionId.Value</small>
            }
        </div>
        <div class="toolbar-actions">
            <label class="pdf-design-selector">
                PDF Design
                <select class="form-control" @bind="SelectedPdfDesign">
                    <option value="@PdfDesign.DesignA">Design A</option>
                    <option value="@PdfDesign.DesignB">Design B</option>
                </select>
            </label>
            <select class="form-control version-label" @bind="SelectedArbeitsversionId" disabled="@IsBusy">
                <option value="">Arbeitsversion waehlen</option>
                @foreach (var arbeitsversion in Arbeitsversionen)
                {
                    <option value="@arbeitsversion.Id">@arbeitsversion.Title (@arbeitsversion.UpdatedAtUtc.ToLocalTime().ToString("g"))</option>
                }
            </select>
            <button class="btn btn-secondary" @onclick="LoadSelectedAsync" disabled="@IsBusy"><i class="bi bi-arrow-repeat"></i> Laden</button>
            <button class="btn btn-secondary" @onclick="GoEditorAsync"><i class="bi bi-arrow-return-left"></i> Zur Arbeitsversion</button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-danger" role="alert">@ErrorMessage</div>
    }

    <div class="context-banner" role="status">
        <i class="bi bi-pencil-square"></i>
        <strong>Variante = feste Kopie. Du kannst sie umbenennen, loeschen, exportieren oder als Arbeitsversion laden.</strong>
    </div>

    <section class="versions-panel">
        <h2>Variantenliste</h2>
        @if (IsBusy)
        {
            <p class="muted">Lade...</p>
        }
        else if (ActiveArbeitsversionId is null)
        {
            <p class="muted">Bitte zuerst eine Arbeitsversion auswaehlen.</p>
        }
        else if (Varianten.Count == 0)
        {
            <p class="muted">Noch keine gespeicherten Varianten vorhanden.</p>
        }
        else
        {
            <table class="table table-sm variants-table">
                <thead>
                <tr>
                    <th>Variante</th>
                    <th>Name</th>
                    <th>Erstellt</th>
                    <th>Aktionen</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var variante in Varianten)
                {
                    <tr>
                        <td><span class='version-badge @VersionBadgeClass(variante.VersionNumber)'>v@DisplayVersionNumber(variante.VersionNumber)</span></td>
                        <td style="min-width: 280px;">
                            <input class="form-control" @bind="variante.Label" />
                        </td>
                        <td>@variante.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                        <td>
                            <div class="variants-actions">
                                <button class="btn btn-sm btn-ghost" @onclick="() => AlsArbeitsversionLadenAsync(variante)"><i class="bi bi-pencil-square"></i> Als Arbeitsversion</button>
                                <button class="btn btn-sm btn-ghost" @onclick="() => UmbenennenAsync(variante)" disabled="@IsBusy"><i class="bi bi-pencil"></i> Umbenennen</button>
                                <button class="btn btn-sm btn-export-pdf" @onclick="() => ExportPdfAsync(variante)"><i class="bi bi-download"></i> PDF</button>
                                <button class="btn btn-sm btn-export-docx" @onclick="() => ExportDocxAsync(variante)"><i class="bi bi-download"></i> DOCX</button>
                                <button class="btn btn-sm btn-danger variant-delete-btn" @onclick="() => LoeschenAsync(variante)" disabled="@IsBusy"><i class="bi bi-trash3"></i> <span class="variant-delete-label">Loeschen</span></button>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </section>
</section>
}

@code {
    [Parameter]
    public Guid? ResumeId { get; set; }

    private Guid? ActiveArbeitsversionId { get; set; }
    private string SelectedArbeitsversionId { get; set; } = string.Empty;
    private string? CurrentArbeitsversionTitle { get; set; }
    private List<CvStudio.Application.DTOs.ResumeSummaryDto> Arbeitsversionen { get; set; } = [];
    private List<CvStudio.Application.DTOs.ResumeVersionDto> Varianten { get; set; } = [];
    private bool IsBusy { get; set; }
    private string? ErrorMessage { get; set; }
    private bool _interactiveReady;
    private bool _accessChecked;
    private bool _pageInitialized;
    private PdfDesign SelectedPdfDesign { get; set; } = PdfDesign.DesignA;

    protected override async Task OnInitializedAsync()
    {
        await Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_accessChecked)
        {
            await Gate.EnsureInitializedAsync();
            _accessChecked = true;
            if (!Gate.HasAccess)
            {
                RedirectToAccess();
                return;
            }
        }

        if (!Gate.HasAccess)
        {
            return;
        }

        if (!_pageInitialized)
        {
            try
            {
                IsBusy = true;
                ErrorMessage = null;

                Arbeitsversionen = (await Api.ListResumesAsync()).ToList();
                if (ResumeId.HasValue)
                {
                    await LoadArbeitsversionAsync(ResumeId.Value);
                }
                _pageInitialized = true;
            }
            catch (Exception ex)
            {
                _pageInitialized = false;
                ErrorMessage = ex.Message;
            }
            finally
            {
                IsBusy = false;
            }

            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!firstRender)
        {
            return;
        }

        _interactiveReady = true;

        if (ResumeId.HasValue || ActiveArbeitsversionId.HasValue)
        {
            return;
        }

        try
        {
            var raw = await Js.InvokeAsync<string?>("CvStudio.getLastResumeId");
            if (Guid.TryParse(raw, out var last))
            {
                await LoadArbeitsversionAsync(last);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Ignore local storage access issues during initial render.
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_pageInitialized || !Gate.HasAccess)
        {
            return;
        }

        if (ResumeId.HasValue && ResumeId.Value != ActiveArbeitsversionId)
        {
            await LoadArbeitsversionAsync(ResumeId.Value);
        }
    }

    private void RedirectToAccess()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        var returnUrl = string.IsNullOrWhiteSpace(relative) ? "/varianten" : $"/{relative}";
        Navigation.NavigateTo($"/access?returnUrl={Uri.EscapeDataString(returnUrl)}", replace: true);
    }

    private async Task LoadSelectedAsync()
    {
        if (!Guid.TryParse(SelectedArbeitsversionId, out var id))
        {
            ErrorMessage = "Bitte Arbeitsversion auswaehlen.";
            return;
        }

        await LoadArbeitsversionAsync(id);
    }

    private async Task LoadArbeitsversionAsync(Guid id)
    {
        try
        {
            IsBusy = true;
            ErrorMessage = null;

            var arbeitsversion = await Api.GetResumeAsync(id);
            Varianten = (await Api.ListVersionsAsync(id)).ToList();
            Arbeitsversionen = (await Api.ListResumesAsync()).ToList();
            ActiveArbeitsversionId = id;
            SelectedArbeitsversionId = id.ToString();
            CurrentArbeitsversionTitle = arbeitsversion.Title;
            if (_interactiveReady)
            {
                await Js.InvokeVoidAsync("CvStudio.setLastResumeId", id.ToString());
            }
            Navigation.NavigateTo($"/varianten/{id}", replace: true);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task AlsArbeitsversionLadenAsync(CvStudio.Application.DTOs.ResumeVersionDto variante)
    {
        if (!ActiveArbeitsversionId.HasValue)
        {
            return;
        }

        var name = string.IsNullOrWhiteSpace(variante.Label) ? $"v{variante.VersionNumber}" : variante.Label;
        await Js.InvokeVoidAsync("CvStudio.notify", $"Variante {name} wird als Arbeitsversion geladen.");
        Navigation.NavigateTo($"/arbeitsversion/{ActiveArbeitsversionId.Value}?versionId={variante.Id}");
    }

    private async Task UmbenennenAsync(CvStudio.Application.DTOs.ResumeVersionDto variante)
    {
        if (!ActiveArbeitsversionId.HasValue)
        {
            return;
        }

        try
        {
            IsBusy = true;
            ErrorMessage = null;
            await Api.UpdateVersionAsync(ActiveArbeitsversionId.Value, variante.Id, new CvStudio.Application.DTOs.UpdateVersionRequest
            {
                Label = string.IsNullOrWhiteSpace(variante.Label) ? null : variante.Label.Trim()
            });
            await LoadArbeitsversionAsync(ActiveArbeitsversionId.Value);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task LoeschenAsync(CvStudio.Application.DTOs.ResumeVersionDto variante)
    {
        if (!ActiveArbeitsversionId.HasValue)
        {
            return;
        }

        var ok = await Js.InvokeAsync<bool>("confirm", $"Variante v{variante.VersionNumber} loeschen?");
        if (!ok)
        {
            return;
        }

        try
        {
            IsBusy = true;
            ErrorMessage = null;
            await Api.DeleteVersionAsync(ActiveArbeitsversionId.Value, variante.Id);
            await LoadArbeitsversionAsync(ActiveArbeitsversionId.Value);
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task ExportPdfAsync(CvStudio.Application.DTOs.ResumeVersionDto variante)
    {
        if (!ActiveArbeitsversionId.HasValue)
        {
            return;
        }

        var bytes = await Api.DownloadPdfAsync(ActiveArbeitsversionId.Value, variante.Id, SelectedPdfDesign);
        var name = string.IsNullOrWhiteSpace(variante.Label) ? $"v{variante.VersionNumber}" : variante.Label.Replace(' ', '-');
        await Js.InvokeVoidAsync("CvStudio.downloadFile", $"variante-{name}.pdf", Convert.ToBase64String(bytes), "application/pdf");
    }

    private async Task ExportDocxAsync(CvStudio.Application.DTOs.ResumeVersionDto variante)
    {
        if (!ActiveArbeitsversionId.HasValue)
        {
            return;
        }

        var bytes = await Api.DownloadDocxAsync(ActiveArbeitsversionId.Value, variante.Id);
        var name = string.IsNullOrWhiteSpace(variante.Label) ? $"v{variante.VersionNumber}" : variante.Label.Replace(' ', '-');
        await Js.InvokeVoidAsync("CvStudio.downloadFile", $"variante-{name}.docx", Convert.ToBase64String(bytes), "application/vnd.openxmlformats-officedocument.wordprocessingml.document");
    }

    private async Task GoEditorAsync()
    {
        if (!ActiveArbeitsversionId.HasValue)
        {
            Navigation.NavigateTo("/");
            return;
        }

        await Js.InvokeVoidAsync("CvStudio.notify", "Zurueck zur Arbeitsversion.");
        Navigation.NavigateTo($"/arbeitsversion/{ActiveArbeitsversionId.Value}");
    }

    private static string VersionBadgeClass(int versionNumber)
    {
        var normalized = Math.Max(versionNumber, 1);
        var index = (normalized - 1) % 3;
        return index switch
        {
            0 => "badge-v1",
            1 => "badge-v2",
            _ => "badge-v3"
        };
    }

    private static int DisplayVersionNumber(int versionNumber) => Math.Max(versionNumber, 1);
}
